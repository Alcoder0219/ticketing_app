# ── Server ───────────────────────────────────────────────
PORT=4000
# Comma-separated list of allowed CORS origins (the Vite frontend)
CORS_ORIGIN=http://localhost:8080,http://localhost:5173

# ── MongoDB ──────────────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/aum_dacro_ticketing
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/aum_dacro_ticketing
MONGODB_URI=mongodb://127.0.0.1:27017/aum_dacro_ticketing

# ── Auth ─────────────────────────────────────────────────
# Use a long random string in production (openssl rand -hex 48)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── Storage ──────────────────────────────────────────────
# "local"      = files saved under ./uploads and served by this server
# "cloudinary" = files uploaded to Cloudinary; MongoDB stores only the secure_url
# (auto-selects cloudinary when the CLOUDINARY_* vars below are set)
STORAGE_DRIVER=cloudinary
STORAGE_DIR=uploads
# Public base URL this server is reachable at (used to build file URLs)
PUBLIC_BASE_URL=http://localhost:4000

# ── Cloudinary ───────────────────────────────────────────
# From Cloudinary Dashboard → Account Details. The API secret is sensitive:
# it lives ONLY here (server-side) and is never exposed to the frontend.
# Leave all three blank to fall back to local-disk storage.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── External integrations (ported from Supabase edge functions) ──
# Leave blank to disable that integration.
LOVABLE_API_KEY=
OPENAI_API_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_ID=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
